# CraftMind Researcher — Environment Configuration

# Required for LLM-powered hypothesis generation, experiment design,
# behavior script creation, evaluation, and distillation.
# Without this, the system operates in offline fallback mode.
ZAI_API_KEY=

# Minecraft server connection (for live bot experiments)
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565
MINECRAFT_USERNAME=CraftMindBot

# Optional: directory for knowledge base storage (defaults to ./knowledge)
KNOWLEDGE_DIR=

# Optional: logging level (debug, info, warn, error)
LOG_LEVEL=info
